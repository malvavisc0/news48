MODEL=granite-4.0-h-micro.i1
API_BASE=http://llamacpp:8080/v1
API_KEY=nokey
CONTEXT_WINDOW=131072
DATA_DIR=/data

# MySQL Database
# IMPORTANT: Change ALL passwords before deploying to production!
# Generate strong passwords: python -c "import secrets; print(secrets.token_urlsafe(32))"
DATABASE_URL=mysql+mysqlconnector://news48:CHANGE_ME@mysql:3306/news48
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=news48
MYSQL_USER=news48
MYSQL_PASSWORD=CHANGE_ME_mysql_password

BYPARR_API_URL=http://byparr:8191/v1
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=CHANGE_ME_searxng_secret   # Generate: python -c "import secrets; print(secrets.token_hex(32))"
# SMTP — defaults to Mailpit in development (docker compose override).
# Set real SMTP credentials for production deployments.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=news48
SMTP_PASS=password
SMTP_FROM=news48@localhost
MONITOR_EMAIL_TO=
MCP_DOMAIN=news48.io
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=4
WEB_LOG_LEVEL=info
WEB_ACCESS_LOG=1
WEB_RELOAD=1
FORWARDED_ALLOW_IPS=127.0.0.1

# Redis / Dramatiq
REDIS_URL=redis://redis:6379/0

# llamacpp service
HF_TOKEN=               # Required for gated/private models on HuggingFace
LLAMACPP_MODEL_REPO=WithinUsAI/Opus4.7-GODs.Ghost.Codex-4B.GGuF
LLAMACPP_MODEL_FILE=Opus4.7-Distill-GODsGhost-Codex-4B-Q4_K_M.gguf
LLAMACPP_CTX_SIZE=131072
LLAMACPP_PORT=8080
LLAMACPP_N_GPU_LAYERS=999
LLAMACPP_PARALLEL=2
LLAMACPP_THREADS=8
LLAMACPP_CACHE_TYPE_K=q4_0
LLAMACPP_CACHE_TYPE_V=q4_0
LLAMACPP_FLASH_ATTN=on

# Parser — keep ≤ LLAMACPP_PARALLEL to avoid LLM context thrashing
PARSER_CONCURRENCY=2

# Article body extraction (trafilatura | none)
ARTICLE_EXTRACTION=trafilatura
