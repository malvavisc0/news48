MODEL=granite-4.0-h-micro.i1
API_BASE=http://llamacpp:8080/v1
API_KEY=nokey
CONTEXT_WINDOW=131072
DATA_DIR=/data

# MySQL Database
DATABASE_URL=mysql+mysqlconnector://news48:news48@mysql:3306/news48
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=news48
MYSQL_USER=news48
MYSQL_PASSWORD=news48

BYPARR_API_URL=http://byparr:8191/v1
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=changeme   # MUST be a strong random string in production! Generate: python -c "import secrets; print(secrets.token_hex(32))"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MONITOR_EMAIL_TO=
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=4
WEB_LOG_LEVEL=info
WEB_ACCESS_LOG=1
WEB_RELOAD=1
FORWARDED_ALLOW_IPS=127.0.0.1

# Redis / Dramatiq
REDIS_URL=redis://redis:6379/0

# llamacpp service
